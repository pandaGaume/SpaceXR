{
    "extends": "../../../tsconfig.json",

    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declarationDir": "./types",
        "skipLibCheck": true,
        "paths": {
            "spacegx/*": ["dev/core/types/*"],
            "shelly/*": ["dev/shelly/types/*"]
        }
    },
    "references": [{ "path": "../core" }],
    "include": ["./src/**/*.ts", "../core/src/materials/glsl.d.ts"],
    "exclude": ["**/node_modules", "**/dist", "**/types"]
}
