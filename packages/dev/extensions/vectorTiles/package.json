{
    "name": "spacexr-vector",
    "version": "1.0.0",
    "main": "dist/index",
    "module": "dist/index",
    "esnext": "dist/index",
    "types": "dist/index",
    "private": true,
    "files": [
        "./src"
    ],
    "scripts": {
        "build:vector:dev": "npm run clean:vector && npm run compile:vector",
        "clean:vector": "rimraf dist && rimraf tsconfig.tsbuildinfo",
        "compile:vector": "npm run compile:vector:source",
        "compile:vector:source": "tsc --project tsconfig.json",
        "webpack:vector:dev": "webpack --mode development",
        "copy:vector:bundle": "copyfiles -V -u 1 \"./bundles/*.*\" \"../../../host/www/libs\"",
        "publish:vector:dev": "npm run build:vector:dev && npm run webpack:vector:dev && npm run copy:vector:bundle"
    },
    "sideEffects": false,
    "devDependencies": {
        "rimraf": "^4.4.1"
    },
    "dependencies": {
        "protobufjs": "^7.3.2",
        "protobufjs-cli": "^1.1.2"
    }
}
