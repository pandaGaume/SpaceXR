{
    "devDependencies": {
        "@babylonjs/core": "^6.49.0",
        "@babylonjs/loaders": "^6.4.1",
        "@types/jest": "^29.5.1",
        "@types/node": "^18.15.10",
        "@typescript-eslint/eslint-plugin": "^5.56.0",
        "@typescript-eslint/parser": "^5.56.0",
        "copyfiles": "^2.4.1",
        "eslint": "8.36.0",
        "jest": "^29.5.0",
        "prettier": "2.8.6",
        "ts-jest": "^29.1.0",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.2",
        "webpack": "^5.78.0",
        "webpack-cli": "^5.0.1"
    },
    "workspaces": [
        "packages/**/*"
    ],
    "scripts": {
        "start": "node -r @dev/build-tools",
        "build:all": "npm install && npm run build:buildTools && npm run build:babylon && npm run build:core && echo All packages builded successfully!",
        "build:buildTools": "cd packages/dev/buildTools && npm run build:build-tools",
        "build:babylon": "cd packages/dev/babylon && npm run build:babylon:assets && npm run publish:babylon:dev",
        "build:core": "cd packages/dev/core && npm run build:core:dev",
        "build:dev": "npm run compile:dev",
        "compile:dev": "tsc -b ./tsconfig.packages.dev.json",
        "test": "jest"
    },
    "dependencies": {
        "@babylonjs/gui": "^6.29.1",
        "quickhull3d": "^2.1.0"
    }
}
