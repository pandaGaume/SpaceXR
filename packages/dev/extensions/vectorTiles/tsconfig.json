{
    "extends": "../../../../tsconfig.json",
    "name": "spacexr-vector",
    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declarationDir": "./types",
        "skipLibCheck": true,
        // paths are used to resolve modules
        "paths": {
            "core/*": ["./dev/core/src/*"]
        }
    },
    // you MUST use reference to the core tsconfig and the babylon-ext tsconfig
    "references": [{ "path": "../../core" }],
    "include": ["./src/**/*.ts", "../../core/src/tiles/vector/tiles.vector.ts"],
    "exclude": ["**/node_modules", "**/dist", "**/types"]
}
