{
    "extends": "../../../tsconfig.json",
    "name": "spacexr-babylon",
    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declarationDir": "./types",
        "skipLibCheck": true,
        "paths": {
            "core/*": ["./dev/core/src/*"] // base url set in parent config
        }
    },
    "references": [{ "path": "../core" }],
    "include": ["./src/**/*.ts"],
    "exclude": ["**/node_modules", "**/dist", "**/types"]
}
