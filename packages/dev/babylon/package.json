{
    "name": "@dev/spacegx.babylon",
    "version": "1.0.0",
    "main": "dist/index",
    "module": "dist/index",
    "esnext": "dist/index",
    "types": "dist/index",
    "private": true,
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build:babylon": "npm run clean:babylon && npm run compile:babylon",
        "clean:babylon": "rimraf dist && rimraf tsconfig.tsbuildinfo",
        "compile:babylon": "npm run precompile:babylon && npm run compile:babylon:source",
        "compile:babylon:source": "tsc --project tsconfig.json",
        "precompile:babylon": "npm run build:babylon:assets",
        "build:babylon:assets": "npx build-tools -c process-assets"
    },
    "sideEffects": false,
    "dependencies": {
        "@dev/core": "^1.0.0"
    },
    "devDependencies": {
        "@dev/build-tools": "^1.0.0"
    }
}
