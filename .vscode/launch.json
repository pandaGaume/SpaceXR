{
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Test Vector",
            "program": "${workspaceFolder}/node_modules/jest/bin/jest.js",
            "args": ["--config", "./jest.config.ts", "--verbose"],
            "outputCapture": "std",
            "internalConsoleOptions": "openOnSessionStart",
            "cwd": "${workspaceFolder}/packages/dev/extensions/mapbox/",
            "windows": {
                "skipFiles": ["C:\\**\\node_modules\\**\\*", "<node_internals>/**/*"]
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Canvas Map on chrome",
            "url": "http://localhost:1338/packages/host/www/core/canvasmap.html",
