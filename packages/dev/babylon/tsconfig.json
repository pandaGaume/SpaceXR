{
    "extends": "../../../tsconfig.json",

    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true,
        "paths": {
            "core/*": ["dev/core/dist/*"],
            "shelly/*": ["dev/shelly/dist/*"]
        }
    },

    "include": ["./src/**/*.ts", "./src/**/*.tsx"],
    "exclude": ["**/node_modules", "**/dist"]
}
