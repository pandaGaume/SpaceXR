{
    "name": "@gaume/spacegx",
    "version": "1.0.0",
    "main": "dist/index",
    "module": "dist/index",
    "esnext": "dist/index",
    "types": "dist/index",
    "private": true,
    "files": [
        "./src",
        "./dist"
    ],
    "scripts": {
        "build": "npm run clean:shaders && npm run copy:shaders && npm run compile",
        "clean:shaders": "rimraf dist/shaders/",
        "copy:shaders": "copyfiles -u 1 ./src/shaders/**/*.glsl dist/",
        "compile": "npm run compile:source",
        "compile:source": "tsc -b tsconfig.json"
    },
    "sideEffects": false,
    "devDependencies": {}
}
