{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "msedge",
            "request": "launch",
            "name": "Launch ms edge against localhost",
            "url": "http://localhost:1338/www/index.html",
            "webRoot": "${workspaceFolder}",
            "runtimeArgs": ["--disable-web-security", "--user-data-dir=C:/Users/guill/edgeTmp"]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:1338/www/index.html",
            "webRoot": "${workspaceFolder}",
            "runtimeArgs": ["--disable-web-security", "--user-data-dir=C:/Users/guill/chromeTmp"]
        }
    ]
}
