{
    "extends": "../../../tsconfig.json",
    "name": "spacexr-core",
    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declarationDir": "./types",
        "skipLibCheck": true,
        "paths": {
            "core/*": ["./dev/core/src/*"]
        }
    },

    "include": ["./src/**/*.ts", "test/unit/tiles/geography.envelope.test.ts"],
    "exclude": ["**/node_modules", "**/dist", "**/types"]
}
