{
    "extends": "../../../tsconfig.json",

    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declarationDir": "./types",
        "skipLibCheck": true,
        "paths": {
            "core/*": ["dev/core/src/*"]
        }
    },

    "include": ["./src/**/*.ts"],
    "exclude": ["**/node_modules", "**/dist", "**/types"]
}
