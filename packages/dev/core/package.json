{
    "name": "@dev/core",
    "version": "1.0.0",
    "main": "dist/index",
    "module": "dist/index",
    "esnext": "dist/index",
    "types": "dist/index",
    "private": true,
    "files": [
        "./src"
    ],
    "scripts": {
        "build:core": "npm run clean:core && npm run compile:core",
        "clean:core": "rimraf dist && rimraf tsconfig.tsbuildinfo",
        "compile:core": "npm run compile:core:source",
        "compile:core:source": "tsc --project tsconfig.json",
        "test": "jest -c ../../../jest.config.ts --verbose"
    },
    "sideEffects": false,
    "devDependencies": {
        "rimraf": "^4.4.1"
    }
}
