{
    "version": "2.0.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Canvas Map on chrome",
            "url": "http://localhost:1338/packages/host/www/canvasmap.html",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "pathMapping": {
                "/": "${workspaceFolder}/packages/dev/core/"
            }
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Launch Canvas Map on ms edge",
            "url": "http://localhost:1338/packages/host/www/canvasmap.html",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "pathMapping": {
                "/": "${workspaceFolder}/packages/dev/core/"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Map on chrome",
            "url": "http://localhost:1338/packages/host/www/babylonmap.html",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "pathMapping": {
                "/core": "${workspaceFolder}/packages/dev/core/",
                "/SpaceXR": "${workspaceFolder}/packages/dev/babylon/"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "MapMaterial on chrome",
            "url": "http://localhost:1338/packages/host/www/babylonmapmaterial.html",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "pathMapping": {
                "/core": "${workspaceFolder}/packages/dev/core/",
                "/SpaceXR": "${workspaceFolder}/packages/dev/babylon/"
            }
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Launch Babylon Map on ms edge",
            "url": "http://localhost:1338/packages/host/www/babylonmapmaterial.html",
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true,
            "pathMapping": {
                "/core": "${workspaceFolder}/packages/dev/core/",
                "/SpaceXR": "${workspaceFolder}/packages/dev/babylon/"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Webgl test on chrome",
            "url": "http://localhost:1338/packages/host/www/webgltrial.html",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
