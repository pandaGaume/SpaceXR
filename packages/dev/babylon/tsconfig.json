{
    "extends": "../../../tsconfig.json",

    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declarationDir": "./types",
        "skipLibCheck": true,
        "paths": {
            "spacegx/*": ["dev/core/types/*"],
            "shelly/*": ["dev/shelly/types/*"]
        }
    },

    "include": ["./src/**/*.ts", "./src/**/*.tsx"],
    "exclude": ["**/node_modules", "**/dist", "**/types"]
}
