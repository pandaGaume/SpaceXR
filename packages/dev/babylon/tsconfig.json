{
    "extends": "../../../tsconfig.json",
    "name": "spacexr-babylon",
    "compilerOptions": {
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "declarationDir": "./types",
        "skipLibCheck": true,
        // paths are used to resolve modules
        "paths": {
            "core/*": ["./dev/core/src/*"],
            "babylon-ext/*": ["./dev/babylon-ext/src/*"]
        }
    },
    // you MUST use reference to the core tsconfig and the babylon-ext tsconfig
    "references": [{ "path": "../core" }, { "path": "../babylon-ext" }],
    "include": ["./src/**/*.ts"],
    "exclude": ["**/node_modules", "**/dist", "**/types"]
}
