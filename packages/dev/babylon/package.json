{
    "name": "spacexr-babylon",
    "version": "1.0.0",
    "main": "dist/index",
    "module": "dist/index",
    "esnext": "dist/index",
    "types": "dist/index",
    "private": true,
    "files": [
        "src"
    ],
    "scripts": {
        "clean:babylon": "rimraf dist && rimraf tsconfig.tsbuildinfo",
        "build:babylon:dev": "npm run clean:babylon && npm run compile:babylon",
        "compile:babylon": "npm run precompile:babylon && npm run compile:babylon:source",
        "compile:babylon:source": "tsc --project tsconfig.json",
        "precompile:babylon": "npm run build:babylon:assets",
        "build:babylon:assets": "npx build-tools -c process-assets",
        "webpack:babylon:dev": "webpack --mode development --stats-error-details",
        "copy:babylon:bundle": "copyfiles -V -u 1 \"./bundles/*.*\" \"../../host/www/libs\"",
        "publish:babylon:dev": "npm run build:babylon:dev && npm run webpack:babylon:dev && npm run copy:babylon:bundle"
    },
    "sideEffects": false,
    "devDependencies": {
        "@dev/build-tools": "^1.0.0"
    },
    "dependencies": {
        "path-scurry": "^1.10.1"
    }
}
